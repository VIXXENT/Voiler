# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL via Docker Compose)
DATABASE_URL=postgresql://voiler:voiler_dev@localhost:5432/voiler_dev

# Auth (generate with: openssl rand -base64 48)
AUTH_SECRET=replace-me-with-at-least-32-characters-long-secret-key

# CORS / Trusted Origins (comma-separated, required in production)
# TRUSTED_ORIGINS=https://myapp.com,https://www.myapp.com

# Telemetry
TURBO_TELEMETRY_DISABLED=1

# [MODULE:payments] Stripe
# [MODULE:payments] STRIPE_SECRET_KEY=
# [MODULE:payments] STRIPE_WEBHOOK_SECRET=

# [MODULE:email] Email (SMTP)
# [MODULE:email] SMTP_HOST=
# [MODULE:email] SMTP_PORT=587
# [MODULE:email] SMTP_USER=
# [MODULE:email] SMTP_PASS=
# [MODULE:email] EMAIL_FROM=noreply@example.com

# OAuth (optional — leave empty to disable)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
