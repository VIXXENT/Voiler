{
  "name": "@voiler/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/trpc-server": "^0.4.2",
    "@trpc/server": "^11.16.0",
    "@voiler/config-env": "workspace:*",
    "@voiler/core": "workspace:*",
    "@voiler/domain": "workspace:*",
    "@voiler/mod-email": "workspace:*",
    "@voiler/mod-payments": "workspace:*",
    "@voiler/schema": "workspace:*",
    "argon2": "^0.44.0",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.7.0",
    "hono-rate-limiter": "^0.4.0",
    "jose": "^6.2.2",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@voiler/config-ts": "workspace:*",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
