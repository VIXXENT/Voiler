{
  "name": "@voiler/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:push": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@voiler/config-env": "workspace:*",
    "@voiler/schema": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "drizzle-orm": "^0.38.0",
    "postgres": "^3.4.0",
    "hono-rate-limiter": "^0.4.0"
  },
  "devDependencies": {
    "@voiler/config-ts": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.30.0"
  }
}
